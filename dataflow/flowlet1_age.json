{
	"name": "flowlet1_age",
	"properties": {
		"type": "Flowlet",
		"typeProperties": {
			"sources": [],
			"sinks": [],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "agecategory"
				},
				{
					"name": "input1"
				},
				{
					"name": "output1"
				}
			],
			"scriptLines": [
				"input(output(",
				"          id as integer,",
				"          name as string,",
				"          city as string,",
				"          age as integer",
				"     ),",
				"     order: 0,",
				"     allowSchemaDrift: true) ~> input1",
				"input1 filter(age>60) ~> filter1",
				"filter1 derive(age_category = iif(age>65, 'Senior', 'Adult')) ~> agecategory",
				"agecategory output() ~> output1"
			]
		}
	}
}